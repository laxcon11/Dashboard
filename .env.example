FRED_API_KEY=your_fred_api_key_here

# GIFT NIFTY display flags
GIFT_NIFTY_DASHBOARD_CARD=1
GIFT_NIFTY_INV_PREFLAG=1
GIFT_NIFTY_MACRO_BADGE=1

# Optional direct API source for GIFT NIFTY
# GIFT_NIFTY_API_URL=https://your-feed-endpoint
# GIFT_NIFTY_API_KEY=your_api_key

# Fallback scrape toggles
GIFT_NIFTY_GROWW_FALLBACK=1
GIFT_NIFTY_MONEYCONTROL_FALLBACK=0

# Classification and window controls
GIFT_NIFTY_FLAT_THRESHOLD_PCT=0.30
GIFT_NIFTY_SESSION_START_IST_HOUR=17
GIFT_NIFTY_COLLAPSE_IST_HOUR=10
